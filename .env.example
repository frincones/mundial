# =============================================================================
# Plantilla de variables de entorno — copiar a .env y completar
# El .env real está en .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# AWS
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=tu-access-key-aqui
AWS_SECRET_ACCESS_KEY=tu-secret-key-aqui
AWS_DEFAULT_REGION=us-east-1
AWS_DEFAULT_OUTPUT=json

# -----------------------------------------------------------------------------
# Supabase
# Obtener desde: Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...legacy-anon-jwt...
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-jwt...
SUPABASE_ACCESS_TOKEN=sbp_xxx
SUPABASE_PROJECT_REF=<project-ref>

# -----------------------------------------------------------------------------
# Vercel
# Generar token en: https://vercel.com/account/tokens
# -----------------------------------------------------------------------------
VERCEL_TOKEN=vcp_xxx

# -----------------------------------------------------------------------------
# GitHub
# Fine-grained PAT: https://github.com/settings/personal-access-tokens
# Permisos: contents/actions/secrets/workflows Read+Write; scope a 1 repo
# -----------------------------------------------------------------------------
GITHUB_REPO_URL=https://github.com/<owner>/<repo>.git
GITHUB_REPO_OWNER=<owner>
GITHUB_REPO_NAME=<repo>
GITHUB_TOKEN=github_pat_xxx
